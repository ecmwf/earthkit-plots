   "source": [
    "import numpy as np\n",
    "\n",
    "import earthkit.plots as ekp\n",
    "\n",
    "chart = ekp.Subplot()\n",
    "\n",
    "data = np.random.randint(0, 11, 20)\n",
    "\n",
    "chart.line(data, drawstyle=\"spline\")\n",
    "\n",
    "chart.show()"
   ]
  }
