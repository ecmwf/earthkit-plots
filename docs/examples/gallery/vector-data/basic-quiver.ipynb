   "source": [
    "## Quiver (arrow) plots"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "1d37c190",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 700x800 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "import earthkit.data as ekd\n",
    "import earthkit.plots as ekp\n",
    "\n",
    "data = ekd.from_source(\"sample\", \"storm_ophelia_wind_850.grib\")\n",
    "\n",
    "chart = ekp.Map(domain=[-20, 5, 40, 60])\n",
    "\n",
    "chart.quiver(data)\n",
    "\n",
    "chart.coastlines()\n",
    "chart.land()\n",
    "chart.gridlines()\n",
    "\n",
    "chart.show()"
   ]
  }
 ],
